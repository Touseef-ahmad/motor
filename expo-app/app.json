{
  "expo": {
    "name": "Motor",
    "slug": "motor",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.motor.app"
    },
    "android": {
      "package": "com.motor.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to let you choose car pictures."
        }
      ]
    ]
  }
}
